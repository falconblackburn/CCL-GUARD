{
  "version": 2,
  "framework": "flask",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "parent_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/director/(.*)",
      "dest": "parent_app.py"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "VERCEL": "1",
    "PYTHON_VERSION": "3.12"
  }
}
